# Copy to .env and fill in. .env is gitignored.

# Slack incoming webhook for alert routing.
# Get one free at: https://api.slack.com/messaging/webhooks
# (any free Slack workspace works; lab does not require paid tier)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/ME/HERE

# Grafana admin password (default: admin/admin works for the lab).
GRAFANA_ADMIN_PW=admin

# Optional: PagerDuty integration key for the BONUS escalation drill.
PD_INTEGRATION_KEY=

# Optional: Day 19 Qdrant URL (lab §05 integration). Leave empty to skip.
DAY19_QDRANT_URL=

# Optional: Day 20 llama.cpp metrics URL (lab §05 integration). Leave empty to skip.
DAY20_LLAMACPP_METRICS_URL=

# Host port for the FastAPI app. Change if port 8000 is already occupied.
APP_PORT=8000